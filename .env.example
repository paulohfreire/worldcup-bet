# Database
DATABASE_URL="postgresql://username:password@localhost:5432/worldcup_bet?schema=public"

# JWT Secret - Required in production, must be at least 32 characters
JWT_SECRET="your-super-secret-jwt-key-change-in-production-minimum-32-chars"

# Environment (development | production)
NODE_ENV="development"

# Allowed CORS origins (comma-separated)
# For production: "https://yourdomain.com,https://www.yourdomain.com"
# For development: "http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000"
